{
  "name": "alt-art-tracker",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/mobile",
    "web": "npm run web --workspace=apps/mobile",
    "ios": "npm run ios --workspace=apps/mobile",
    "android": "npm run android --workspace=apps/mobile",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset",
    "supabase:types": "supabase gen types typescript --local 2>/dev/null > packages/shared/database.types.ts",
    "supabase:functions": "supabase functions serve --no-verify-jwt --env-file supabase/functions/.env",
    "import:pokemon": "tsx scripts/import-pokemon-cards.ts",
    "invite:new": "tsx scripts/generate-invite.ts"
  },
  "devDependencies": {
    "tsx": "^4.20.0"
  },
  "engines": {
    "node": ">=20"
  }
}
