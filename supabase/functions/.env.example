# Edge Function secrets — copy to supabase/functions/.env (gitignored).
# When all TWILIO_* vars are set, verify-phone uses real Twilio Verify.
# When any are missing, it falls back to dev mode: code "000000" always works,
# no SMS is sent. This lets you iterate on the UX before paying for Twilio.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# eBay (pending — Ian is waiting on Developer account / API approval).
# When credentials land, the scrape-ebay-sold Edge Function (TBD) will use:
#   EBAY_CLIENT_ID                — OAuth client id
#   EBAY_CLIENT_SECRET            — OAuth client secret
#   EBAY_USE_MARKETPLACE_INSIGHTS — "true" if Marketplace Insights API is approved
#                                   (gives real sold listings); otherwise the
#                                   function falls back to Browse API (active
#                                   listings only — less accurate).

# PriceCharting was dropped from the plan — they no longer offer a public API
# for new accounts. TCGplayer market prices come from the Pokemon TCG API
# (free, no auth) via npm run refresh:prices.
