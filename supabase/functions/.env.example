# Edge Function secrets — copy to supabase/functions/.env (gitignored).
# When all TWILIO_* vars are set, verify-phone uses real Twilio Verify.
# When any are missing, it falls back to dev mode: code "000000" always works,
# no SMS is sent. This lets you iterate on the UX before paying for Twilio.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Reddit Developer app credentials (free; reddit.com/prefs/apps).
# When set, scrape-reddit-mentions hits the real Reddit search API.
# When missing, it returns synthetic mention counts (0–3 per card).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# eBay (pending — Ian is waiting on Developer account / API approval).
# When credentials land, the scrape-ebay-sold Edge Function (TBD) will use:
#   EBAY_CLIENT_ID                — OAuth client id
#   EBAY_CLIENT_SECRET            — OAuth client secret
#   EBAY_USE_MARKETPLACE_INSIGHTS — "true" if Marketplace Insights API is approved
#                                   (gives real sold listings); otherwise the
#                                   function falls back to Browse API (active
#                                   listings only — less accurate).

# PriceCharting was dropped from the plan — they no longer offer a public API
# for new accounts. TCGplayer market prices come from the Pokemon TCG API
# (free, no auth) via npm run refresh:prices.

# Anthropic API for ai-research-releases Edge Function.
# Model: claude-sonnet-4-5 (override via ANTHROPIC_MODEL).
# Web search tool ($0.01/call) + Sonnet pricing — $5/week cost cap
# enforced inside the function.
ANTHROPIC_API_KEY=

# PSA Public API for grading data — pop reports + recent graded sales.
# Phase 2 only; integration not built yet. Token loaded here so it's
# available when the Edge Function lands.
PSA_API_TOKEN=

# eBay Developer App — sold listings + active listings.
# Get from: developer.ebay.com → My Account → Application Keys.
# CLIENT_ID = App ID, CLIENT_SECRET = Cert ID. Browse API works as soon
# as keys are set; Marketplace Insights API requires a separate approval
# (often takes weeks).
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# Set to 'true' once Marketplace Insights API access is granted; the
# scraper falls back to Browse API (active listings only) when 'false'.
EBAY_USE_MARKETPLACE_INSIGHTS=
# Optional: eBay Partner Network ID for affiliate links — separate
# program, not needed for data ingestion.
EBAY_PARTNER_ID=

# Reddit Developer App — community mention counts.
# Get from: reddit.com/prefs/apps → 'create another app...' → 'script'.
# Read-only OAuth (client_credentials) — no user account needed.
REDDIT_USER_AGENT=AltArtTracker/0.1 by /u/altarttracker
