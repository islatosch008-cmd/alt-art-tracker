# Edge Function secrets — copy to supabase/functions/.env (gitignored).
# When all TWILIO_* vars are set, verify-phone uses real Twilio Verify.
# When any are missing, it falls back to dev mode: code "000000" always works,
# no SMS is sent. This lets you iterate on the UX before paying for Twilio.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Anthropic API for ai-research-releases Edge Function.
# Model: claude-sonnet-4-5 (override via ANTHROPIC_MODEL).
# Web search tool ($0.01/call) + Sonnet pricing. Runs monthly; an
# in-function cost guard caps each run at $5 (~$1.50 in practice).
ANTHROPIC_API_KEY=

# JustTCG API — pricing/sales data across all TCGs, powers the Trending
# tab. Free-tier limits: 1,000 calls/month, 100/day, 20 cards/request.
JUSTTCG_API_KEY=

# eBay Developer App — sold listings + active listings.
# Get from: developer.ebay.com → My Account → Application Keys.
# CLIENT_ID = App ID, CLIENT_SECRET = Cert ID. Browse API (active
# listings) works as soon as keys are set; Marketplace Insights API
# (sold listings) requires a separate approval — often takes weeks.
# Without these set, scrape-ebay-active and scrape-ebay-sold both 412
# with a hint and record a degraded outcome to api_request_log.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# Set to 'true' once Marketplace Insights API access is granted. While
# 'false' (or unset), scrape-ebay-sold 412s — by design, since we don't
# want to silently fall back to active-listing data and mislabel it as
# "sold". Active listings are still served by scrape-ebay-active.
EBAY_USE_MARKETPLACE_INSIGHTS=
# Optional: eBay Partner Network ID for affiliate links — separate
# program from the Developer app, not needed for data ingestion.
EBAY_PARTNER_ID=

# Sentry DSN for Edge Function error reporting. When set, withSentry
# captures uncaught throws and recordOutcome fires captureException on
# the SECOND consecutive failure for the same source. Without it, both
# helpers are no-ops and only console.error remains.
SENTRY_DSN=
SENTRY_ENV=

# Twilio outbound SMS — used by process-notifications when sending
# alerts. Required for SMS sends; verify-phone uses the Verify SID
# above and is independent of this number.
TWILIO_FROM_NUMBER=

# Optional — only used by scripts/smoke-twilio-verify.ts to exercise
# Twilio Verify start/check end-to-end against a real phone. E.164
# format: leading '+', country code, no spaces or dashes.
# Example: +15125551234
TEST_PHONE_NUMBER=
